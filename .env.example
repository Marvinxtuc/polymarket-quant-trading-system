# Runtime
DRY_RUN=true
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=45

# Strategy: comma-separated wallet addresses you want to follow
WATCH_WALLETS=0x916f7165c2c836aba22edb6453cdbb5f3ea253ba,0xdb2223cc5202a4718c3069f577ec971f71c96478,0xbddf61af533ff524d27154e589d2d7a81510c684
# Wallet discovery (Polymarket activity stream)
WALLET_DISCOVERY_ENABLED=true
WALLET_DISCOVERY_MODE=union
WALLET_DISCOVERY_PATHS=/trades
WALLET_DISCOVERY_LIMIT=300
WALLET_DISCOVERY_TOP_N=50
WALLET_DISCOVERY_MIN_EVENTS=2
WALLET_DISCOVERY_REFRESH_SECONDS=900
# Wallet screening (must have real Polymarket active positions to be monitored)
MIN_WALLET_ACTIVE_POSITIONS=2
MIN_WALLET_UNIQUE_MARKETS=2
MIN_WALLET_TOTAL_NOTIONAL_USD=500
MAX_WALLET_TOP_MARKET_SHARE=0.85
MIN_WALLET_INCREASE_USD=300
MAX_SIGNALS_PER_CYCLE=1
STALE_POSITION_MINUTES=20
STALE_POSITION_TRIM_PCT=0.6
STALE_POSITION_TRIM_COOLDOWN_SECONDS=300
STALE_POSITION_CLOSE_NOTIONAL_USD=8
TOKEN_REENTRY_COOLDOWN_SECONDS=900
TOKEN_ADD_COOLDOWN_SECONDS=240
CONGESTED_UTILIZATION_THRESHOLD=0.8
CONGESTED_STALE_MINUTES=10
CONGESTED_TRIM_PCT=0.65

# Risk
BANKROLL_USD=5000
RISK_PER_TRADE_PCT=0.01
DAILY_MAX_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=8
MIN_PRICE=0.08
MAX_PRICE=0.92

# APIs
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# LIVE ONLY
PRIVATE_KEY=
FUNDER_ADDRESS=
