# Runtime
DRY_RUN=true
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=45

# Strategy: comma-separated wallet addresses you want to follow
WATCH_WALLETS=0x916f7165c2c836aba22edb6453cdbb5f3ea253ba,0xdb2223cc5202a4718c3069f577ec971f71c96478,0xbddf61af533ff524d27154e589d2d7a81510c684
# Wallet discovery (Polymarket activity stream)
WALLET_DISCOVERY_ENABLED=true
WALLET_DISCOVERY_MODE=union
WALLET_DISCOVERY_PATHS=/trades
WALLET_DISCOVERY_LIMIT=300
WALLET_DISCOVERY_TOP_N=50
WALLET_DISCOVERY_MIN_EVENTS=2
WALLET_DISCOVERY_REFRESH_SECONDS=900
WALLET_DISCOVERY_QUALITY_BIAS_ENABLED=true
WALLET_DISCOVERY_QUALITY_TOP_N=16
WALLET_DISCOVERY_HISTORY_BONUS=0.75
WALLET_DISCOVERY_TOPIC_BONUS=0.5
WALLET_SCORE_PATH=/tmp/poly_runtime_data/wallet_scores.json
WALLET_HISTORY_PATH=/tmp/poly_runtime_data/wallet_history.json
WALLET_HISTORY_REFRESH_SECONDS=1800
WALLET_HISTORY_MAX_WALLETS=12
WALLET_HISTORY_CLOSED_LIMIT=20
WALLET_HISTORY_RESOLUTION_LIMIT=8
MIN_WALLET_SCORE=50
WALLET_SCORE_WATCH_MULTIPLIER=0.4
WALLET_SCORE_TRADE_MULTIPLIER=0.75
WALLET_SCORE_CORE_MULTIPLIER=1.0
TOPIC_BIAS_ENABLED=true
TOPIC_MIN_SAMPLES=3
TOPIC_POSITIVE_ROI=0.08
TOPIC_POSITIVE_WIN_RATE=0.6
TOPIC_NEGATIVE_ROI=-0.02
TOPIC_NEGATIVE_WIN_RATE=0.45
TOPIC_BOOST_MULTIPLIER=1.1
TOPIC_PENALTY_MULTIPLIER=0.9
WALLET_EXIT_FOLLOW_ENABLED=true
MIN_WALLET_DECREASE_USD=200
RESONANCE_EXIT_ENABLED=true
RESONANCE_MIN_WALLETS=2
RESONANCE_MIN_WALLET_SCORE=65
RESONANCE_TRIM_FRACTION=0.35
RESONANCE_CORE_EXIT_FRACTION=0.6
WALLET_SIGNAL_SOURCE=hybrid
WALLET_SIGNAL_LOOKBACK_SECONDS=900
WALLET_SIGNAL_PAGE_SIZE=100
WALLET_SIGNAL_MAX_PAGES=2
# Wallet screening (must have real Polymarket active positions to be monitored)
MIN_WALLET_ACTIVE_POSITIONS=2
MIN_WALLET_UNIQUE_MARKETS=2
MIN_WALLET_TOTAL_NOTIONAL_USD=500
MAX_WALLET_TOP_MARKET_SHARE=0.85
MIN_WALLET_INCREASE_USD=300
MAX_SIGNALS_PER_CYCLE=1
PORTFOLIO_NETTING_ENABLED=true
MAX_CONDITION_EXPOSURE_PCT=0.015
STALE_POSITION_MINUTES=20
STALE_POSITION_TRIM_PCT=0.6
STALE_POSITION_TRIM_COOLDOWN_SECONDS=300
STALE_POSITION_CLOSE_NOTIONAL_USD=8
TOKEN_REENTRY_COOLDOWN_SECONDS=900
TOKEN_ADD_COOLDOWN_SECONDS=240
CONGESTED_UTILIZATION_THRESHOLD=0.8
CONGESTED_STALE_MINUTES=10
CONGESTED_TRIM_PCT=0.65
REPLAY_ENTRY_SLIPPAGE_BPS=0
REPLAY_EXIT_SLIPPAGE_BPS=0
REPLAY_TAKER_FEE_BPS=0
REPLAY_ENTRY_SPREAD_MULTIPLIER=0
REPLAY_EXIT_SPREAD_MULTIPLIER=0
REPLAY_EDGE_PRICE_PENALTY_BPS=0
REPLAY_FEE_KEYWORDS=crypto,加密,ncaab,serie a,serie-a,seriea

# Risk
BANKROLL_USD=5000
RISK_PER_TRADE_PCT=0.01
DAILY_MAX_LOSS_PCT=0.03
MAX_OPEN_POSITIONS=8
MIN_PRICE=0.08
MAX_PRICE=0.92

# APIs
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
LEDGER_PATH=/tmp/poly_runtime_data/ledger.jsonl
ACCOUNT_SYNC_REFRESH_SECONDS=300
PENDING_ORDER_TIMEOUT_SECONDS=1800
USER_STREAM_ENABLED=true
USER_STREAM_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
USER_STREAM_PING_INTERVAL_SECONDS=10
USER_STREAM_RECONNECT_SECONDS=5
USER_STREAM_BUFFER_SIZE=1000
LIVE_NETWORK_SMOKE_MAX_AGE_SECONDS=43200
LIVE_ALLOWANCE_READY=false
LIVE_GEOBLOCK_READY=false
LIVE_ACCOUNT_READY=false

# LIVE ONLY
CLOB_SIGNATURE_TYPE=0
PRIVATE_KEY=
FUNDER_ADDRESS=
