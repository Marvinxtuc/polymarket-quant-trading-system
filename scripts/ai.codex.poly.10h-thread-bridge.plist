<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.codex.poly.10h-thread-bridge</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/tmp/poly_10h_thread_bridge/start_10h_thread_bridge.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/tmp/poly_10h_thread_bridge</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/tmp/poly_10h_thread_bridge.launchd.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/poly_10h_thread_bridge.launchd.err.log</string>
</dict>
</plist>
